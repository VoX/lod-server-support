{
  "schemaVersion": 1,
  "id": "lss",
  "version": "${version}",
  "name": "LOD Server Support",
  "description": "Fabric client/server Mod that provides unofficial multiplayer support for Voxy.",
  "authors": [
    "VoX"
  ],
  "contact": {
    "sources": "https://github.com/VoX/lod-server-support"
  },
  "license": "MIT",
  "icon": "assets/lss/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.vox.lss.LSSMod"
    ],
    "client": [
      "dev.vox.lss.LSSClient"
    ]
  },
  "mixins": [
    "lss.mixins.json"
  ],
  "depends": {
    "minecraft": "1.20.1",
    "fabricloader": ">=0.18.4",
    "fabric-api": ">=0.92.0"
  },
  "suggests": {
    "sodium": "*",
    "modmenu": "*"
  }
}