{
  "schemaVersion": 1,
  "id": "lss",
  "version": "${version}",
  "name": "LOD Server Support",
  "description": "LOD Server Support (aka LSS) is a Fabric client/server mod and Paper Plugin that provides unofficial multiplayer support for Voxy.",
  "authors": [
    "VoX"
  ],
  "contact": {
    "sources": "https://github.com/VoX/lod-server-support"
  },
  "license": "MIT",
  "icon": "assets/lss/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.vox.lss.LSSMod"
    ],
    "client": [
      "dev.vox.lss.LSSClient"
    ],
    "sodium:config_api_user": [
      "dev.vox.lss.config.LSSConfigMenu"
    ],
    "modmenu": [
      "dev.vox.lss.config.LSSModMenuIntegration"
    ]
  },
  "mixins": [
    "lss.mixins.json"
  ],
  "depends": {
    "minecraft": ["1.21.11"],
    "fabricloader": ">=0.14.22",
    "fabric-api": ">=0.91.1"
  },
  "suggests": {
    "sodium": ">=0.8.6",
    "modmenu": "*"
  }
}
