# Client snapshot schema contract — flattened "dotted.key=javatype" lines, sorted.
# Pins BenchmarkMetricsExporter.buildClientSnapshot with a live LodRequestManager and
# probes armed as exactly "7:-3". ExporterContractTest requires EXACT equality, and the
# manager-null (enabled=false) zero-fill branch must emit the IDENTICAL key set.
# Editing this file is a wire-adjacent schema change: scripts/check_soak.py KNOWN keys
# and docs/soak-test-design.md (PKG-CHK) must move in lockstep.
columns.dirty=int
columns.empty=int
columns.known=int
columns.satisfied=int
dimension=string
dropped=long
effective_lod=int
ingest_failures=long
probes.7:-3=long
queued=int
received_bytes=long
received_columns=long
requested_total=long
responses.columns=long
responses.not_generated=long
responses.up_to_date=long
rtt.p50_ms=double
rtt.p95_ms=double
scan.budget=int
scan.confirmed=int
scan.missing_vanilla=int
scan.queued=int
scan.ring=int
send_cycles=long
server_enabled=boolean
tracker_in_flight=int
